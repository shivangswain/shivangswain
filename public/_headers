# Headers (Cloudflare Pages / Netlify-style _headers file).
# First matching rule wins per-header, so specific rules go above the catch-all.

# Fingerprinted build assets — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff2

# Favicons / app icons — cached a day with revalidation (they change rarely).
/*.ico
  Cache-Control: public, max-age=86400, must-revalidate
/*.png
  Cache-Control: public, max-age=86400, must-revalidate
/*.svg
  Cache-Control: public, max-age=86400, must-revalidate

# HTML entry points — never immutable, so returning visitors always revalidate
# to the latest build (304s keep it cheap).
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/404.html
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Catch-all — security headers + defaults. CSP allows the Google Fonts and
# Font Awesome kit hosts that serve the icon-font CSS, binaries, and loader.
/*
  # --- Security ---
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://kit.fontawesome.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com https://ka-f.fontawesome.com; connect-src 'self' https://cloudflareinsights.com https://ka-f.fontawesome.com; media-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests

  # --- Performance ---
  Accept-CH: Sec-CH-UA, Sec-CH-UA-Mobile, Sec-CH-UA-Platform
  X-DNS-Prefetch-Control: on
  Timing-Allow-Origin: *
